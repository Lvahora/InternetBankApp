<Window x:Class="InternetBankApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏦 Интернет-Банк" Height="700" Width="1100"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4361EE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A56D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E9ECEF"/>
            <Setter Property="Foreground" Value="#2B2D42"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,8,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <DropShadowEffect x:Key="CardShadow" Color="#00000033" BlurRadius="20" ShadowDepth="5"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="20" Padding="20" Effect="{StaticResource CardShadow}" Margin="0,0,20,0">
            <StackPanel>
                <Border Background="#4361EE" CornerRadius="15" Padding="15" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="Саликов Вася" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="7-598-345-65-33" FontSize="14" Foreground="#E0E7FF" Margin="0,5,0,0"/>
                        <TextBlock Text="vasylki563@mail.ru" FontSize="14" Foreground="#E0E7FF" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="💳 Мои счета" Style="{StaticResource Label}" FontSize="18"/>
                <ListBox x:Name="AccountsList" SelectionChanged="AccountsList_SelectionChanged" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource {x:Type ListBoxItem}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F8F9FA" CornerRadius="10" Padding="12" Margin="0,5">
                                <StackPanel>
                                    <TextBlock Text="{Binding AccountNumber}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Balance, StringFormat='Баланс: {0} ₽'}" FontSize="14" Foreground="#6C757D"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Separator Margin="0,25" Background="#DEE2E6"/>

                <Button Content="Перевод средств" Click="ShowTransfer_Click" Style="{StaticResource SecondaryButton}" Margin="0,8" HorizontalAlignment="Stretch" Width="224"/>
                <Button Content="История операций" Click="ShowStatement_Click" Style="{StaticResource SecondaryButton}" Margin="0,8" HorizontalAlignment="Stretch" Width="224"/>
                <Button Content="Кредитный калькулятор" Click="ShowLoanCalc_Click" Style="{StaticResource SecondaryButton}" Margin="0,8" HorizontalAlignment="Stretch" Width="225"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="30" Effect="{StaticResource CardShadow}">
            <Grid>
                <StackPanel x:Name="TransferPanel" Visibility="Visible">
                    <TextBlock Text="💸 Перевод средств" Style="{StaticResource PageTitle}"/>
                    <Border Background="#F8F9FA" CornerRadius="15" Padding="20" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="Счёт отправителя" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtSender" IsReadOnly="True" Style="{StaticResource ModernTextBox}" Background="#E9ECEF" FontWeight="SemiBold"/>

                            <TextBlock Text="ID счёта получателя" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtReceiver" Style="{StaticResource ModernTextBox}" GotFocus="TxtReceiver_GotFocus" LostFocus="TxtReceiver_LostFocus"/>

                            <TextBlock Text="Сумма перевода (₽)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtAmount" Style="{StaticResource ModernTextBox}" Text="0" PreviewTextInput="Amount_PreviewTextInput" TextChanged="TxtAmount_TextChanged"/>

                            <Border Background="#E3F2FD" CornerRadius="10" Padding="15" Margin="0,15,0,0">
                                <StackPanel>
                                    <TextBlock Text="ℹ️ Информация о комиссии" FontSize="15" FontWeight="SemiBold" Foreground="#1976D2"/>
                                    <TextBlock x:Name="LblCommissionInfo" FontSize="14" Foreground="#495057" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button Content="✅ Выполнить перевод" Click="DoTransfer_Click" Style="{StaticResource PrimaryButton}" Margin="0,25,0,0" Width="220" Height="50" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="LblResult" FontSize="18" FontWeight="SemiBold" Margin="0,20,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="StatementPanel" Visibility="Collapsed">
                    <TextBlock Text="📄 История операций" Style="{StaticResource PageTitle}"/>
                    <Border Background="#F8F9FA" CornerRadius="15" Padding="20">
                        <Grid Cursor="">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="GridStatement" 
                                      AutoGenerateColumns="False" 
                                      Background="White" 
                                      BorderThickness="0"
                                      FontSize="18"
                                      RowHeight="65"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal" 
                                      AlternatingRowBackground="#F8F9FA"
                                      CanUserResizeRows="False"
                                      CanUserAddRows="False"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      MaxHeight="450">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="FontSize" Value="18"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#495057"/>
                                        <Setter Property="Padding" Value="15,15"/>
                                        <Setter Property="Background" Value="#E9ECEF"/>
                                        <Setter Property="Height" Value="50"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="📅 Дата" Binding="{Binding Date}" Width="160" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                                    <DataGridTextColumn Header="🔄 Тип" Binding="{Binding Type}" Width="120"/>
                                    <DataGridTextColumn Header="📤 Откуда" Binding="{Binding SenderAccount}" Width="160"/>
                                    <DataGridTextColumn Header="📥 Куда" Binding="{Binding ReceiverAccount}" Width="140"/>
                                    <DataGridTextColumn Header="💰 Сумма" Binding="{Binding Amount}" Width="130"/>
                                    <DataGridTextColumn Header="⚙️ Комиссия" Binding="{Binding Commission}" Width="130"/>
                                    <DataGridTextColumn Header="🧾 Итого" Binding="{Binding TotalAmount}" Width="140" FontWeight="Bold"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="LoanPanel" Visibility="Collapsed">
                    <TextBlock Text="🧮 Кредитный калькулятор" Style="{StaticResource PageTitle}"/>
                    <Border Background="#F8F9FA" CornerRadius="15" Padding="25">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="💵 Сумма кредита (₽)" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="LoanAmount" Style="{StaticResource ModernTextBox}" Text="100000"/>
                                    <TextBlock Text="📊 Ставка (% годовых)" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="LoanRate" Style="{StaticResource ModernTextBox}" Text="12"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="📅 Срок (месяцев)" Style="{StaticResource Label}"/>
                                    <TextBox x:Name="LoanTerm" Style="{StaticResource ModernTextBox}" Text="12"/>
                                    <Button Content="🔢 Рассчитать" Click="CalcLoan_Click" Style="{StaticResource PrimaryButton}" Margin="0,32,0,0" Width="180"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#E8F5E9" CornerRadius="12" Padding="20" Margin="0,25,0,0">
                                <StackPanel>
                                    <TextBlock Text="📋 Результат расчёта" FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                                    <TextBlock x:Name="LoanResult" FontSize="22" FontWeight="Bold" Foreground="#1B5E20" Margin="0,12,0,0"/>
                                    <TextBlock x:Name="LoanDetails" FontSize="15" Foreground="#555" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>